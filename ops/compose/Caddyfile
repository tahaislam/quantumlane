# Caddy config for QuantumLane.
#
# Serves:
#   /                → static website
#   /static/*        → static assets (JS, CSS)
#   /v1/*            → FastAPI (versioned API + health)
#   /api/docs        → FastAPI OpenAPI docs (/api/* prefix is stripped → FastAPI /docs)
#   /api/*           → FastAPI
#   /mcp*            → MCP server (FastMCP, streamable HTTP). Path PRESERVED (not stripped).
#   /dagster/*       → Dagster UI (dedicated port 3000; not exposed in prod)
#
# Local dev: use http://localhost:8080 (the :8080 site below).
# Prod: quantumlane.io; Caddy auto-provisions TLS.
#
# Route-handling note: /api/* uses `handle_path` (STRIPS the prefix, so /api/docs →
# FastAPI /docs), but /mcp* uses plain `handle` (PRESERVES the path, because the
# FastMCP app's own route is /mcp — stripping it would 404). Don't unify these; the
# two services want opposite prefix behavior.

# -------------------- local --------------------
:8080 {
    # /api/* is stripped and forwarded to FastAPI. So /api/docs -> FastAPI /docs.
    handle_path /api/* {
        reverse_proxy api:8000
    }
    # Versioned API and health probe keep their original path.
    handle /v1/* {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    # MCP server. Path is PRESERVED (handle, not handle_path) — the FastMCP app
    # serves at /mcp, so Caddy must forward /mcp intact. mcp:8100 is reached over
    # the compose network (the mcp service publishes no host port).
    handle /mcp* {
        reverse_proxy mcp:8100
    }
    handle {
        root * /srv/website
        try_files {path} {path}.html /index.html
        file_server
    }

    encode gzip zstd
    log {
        output stdout
        format console
    }
}

# Dagster UI on its own port. Dagster's HTML references absolute paths (/assets, /graphql),
# which makes proxying it under a subpath messy. A dedicated port is the clean answer.
:3000 {
    reverse_proxy dagster-webserver:3000
}

# -------------------- production --------------------
# Redirect www → bare domain (this block ONLY redirects, never serves).
www.quantumlane.io {
    redir https://quantumlane.io{uri} permanent
}

# Bare domain serves the site.
quantumlane.io {
    # Dagster is NOT exposed in prod. Access via SSH tunnel:
    #   ssh -L 3000:localhost:3000 hetzner-box
    # then browse http://localhost:3000

    handle_path /api/* {
        reverse_proxy api:8000
    }
    handle /v1/* {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    # MCP server — public endpoint for LLM clients (Claude, ChatGPT) at
    # https://quantumlane.io/mcp. Path PRESERVED (handle, not handle_path): the
    # FastMCP app's route is /mcp. If this ever 404s, this stripping choice is the
    # first thing to check. If streamed tool calls hang/truncate, add
    # `{ flush_interval -1 }` to disable response buffering.
    handle /mcp* {
        reverse_proxy mcp:8100
    }
    handle {
        root * /srv/website
        try_files {path} {path}.html /index.html
        file_server
    }

    encode gzip zstd
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    log {
        output stdout
        format console
    }
}