# Caddy config for QuantumLane.
#
# Serves:
#   /                → static website
#   /static/*        → static assets (JS, CSS)
#   /v1/*            → FastAPI
#   /api/docs        → FastAPI OpenAPI docs
#   /api/*           → FastAPI
#   /dagster/*       → Dagster UI (optional, can be disabled in prod if you don't want it public)
#
# Local dev: use http://localhost:8080 (the :local site below).
# Prod: replace `quantumlane.io` with your actual domain. Caddy auto-provisions TLS.

# -------------------- local --------------------
:8080 {
    # /api/* is stripped and forwarded to FastAPI. So /api/docs -> FastAPI /docs.
    handle_path /api/* {
        reverse_proxy api:8000
    }
    # Versioned API and health probe keep their original path.
    handle /v1/* {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    handle {
        root * /srv/website
        try_files {path} {path}.html /index.html
        file_server
    }

    encode gzip zstd
    log {
        output stdout
        format console
    }
}

# Dagster UI on its own port. Dagster's HTML references absolute paths (/assets, /graphql),
# which makes proxying it under a subpath messy. A dedicated port is the clean answer.
:3000 {
    reverse_proxy dagster-webserver:3000
}

# -------------------- production --------------------
# Redirect www → bare domain (this block ONLY redirects, never serves).
www.quantumlane.io {
    redir https://quantumlane.io{uri} permanent
}

# Bare domain serves the site.
quantumlane.io {
    # Dagster is NOT exposed in prod. Access via SSH tunnel:
    #   ssh -L 3000:localhost:3000 hetzner-box
    # then browse http://localhost:3000

    handle_path /api/* {
        reverse_proxy api:8000
    }
    handle /v1/* {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    handle {
        root * /srv/website
        try_files {path} {path}.html /index.html
        file_server
    }

    encode gzip zstd
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    log {
        output stdout
        format console
    }
}
