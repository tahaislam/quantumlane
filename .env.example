# QuantumLane environment template.
# Copy this file to .env and fill in the values. Never commit .env.
#
# Vars prefixed QL_ are read by both ingestion and api packages.
# Vars without a prefix are consumed by docker compose directly.

# --- Environment ---
QL_ENVIRONMENT=development          # development | staging | production
QL_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- Postgres (app data) ---
POSTGRES_USER=quantumlane
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=quantumlane

# DSN used by all services to reach the main DB. Hostname 'postgres' resolves inside the compose network.
QL_POSTGRES_DSN=postgresql://quantumlane:change-me-please@postgres:5432/quantumlane

# --- Postgres (Dagster metadata, separate DB) ---
DAGSTER_POSTGRES_PASSWORD=change-me-too

# --- TTC GTFS-RT feeds ---
# These defaults point to the TTC's public endpoints. Override for testing.
QL_TTC_VEHICLE_POSITIONS_URL=https://bustime.ttc.ca/gtfsrt/vehicles
QL_TTC_TRIP_UPDATES_URL=https://bustime.ttc.ca/gtfsrt/trips
QL_TTC_SERVICE_ALERTS_URL=https://bustime.ttc.ca/gtfsrt/alerts
QL_TTC_STATIC_GTFS_URL=https://opendata.toronto.ca/ttc/routes-and-schedules/OpenData_TTC_Schedules.zip

# --- HTTP client ---
QL_HTTP_TIMEOUT_SECONDS=15
QL_HTTP_USER_AGENT=QuantumLane/0.1 (https://quantumlane.io; contact@quantumlane.io)

# --- Cloudflare R2 (optional in dev) ---
# QL_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# QL_R2_ACCESS_KEY_ID=
# QL_R2_SECRET_ACCESS_KEY=
# QL_R2_BUCKET=quantumlane

# --- API ---
# Comma-separated list or JSON array, depending on how pydantic-settings is configured.
QL_CORS_ORIGINS=["http://localhost:8080","https://quantumlane.io"]
QL_RATE_LIMIT_PER_MINUTE=60

# --- Deployment (for the deploy script) ---
# DEPLOY_HOST=ql@quantumlane.io
